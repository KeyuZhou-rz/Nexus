# Nexus LLM config (OpenAI-compatible API)
NEXUS_LLM_ENABLED="0"
NEXUS_LLM_BASE_URL="https://api.deepseek.com"
NEXUS_LLM_MODEL="deepseek-chat"
NEXUS_LLM_API_KEY=""
NEXUS_LLM_JSON_OUTPUT="1"
# Optional
NEXUS_LLM_TIMEOUT="20"

# Optional sync (minutes; 0 disables auto sync)
NEXUS_GCAL_SYNC_MINUTES="15"
